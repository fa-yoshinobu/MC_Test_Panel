<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>McTestPanel</AssemblyName>
    <RootNamespace>McTestPanel</RootNamespace>
    <ApplicationIcon>..\icon.ico</ApplicationIcon>
    <Product>MC Test Panel</Product>
    <Description>MC Test Panel</Description>
    <Company>fa-yoshinobu</Company>
    <Copyright>Copyright (c) 2026 fa-yoshinobu</Copyright>
    <Version>1.0.0</Version>
    <FileVersion>1.0.0</FileVersion>
    <InformationalVersion>1.0.0</InformationalVersion>
    <IncludeSourceRevisionInInformationalVersion>false</IncludeSourceRevisionInInformationalVersion>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="McpX" Version="0.6.0" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="LICENSE.txt" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
